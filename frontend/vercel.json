{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": {
      "description": "URL of your deployed Railway backend",
      "value": "https://your-app.up.railway.app"
    }
  }
}
